# LifeOS Backend Configuration
DATABASE_URL=postgresql+asyncpg://lifeos:lifeos_dev@localhost:5432/lifeos
JWT_SECRET=change-me-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=lifeos_server
MQTT_PASSWORD=lifeos_server_pass

# Google OAuth (Web client): must match EXPO_PUBLIC_GOOGLE_CLIENT_ID on the app; redirect URI
# https://<your-backend-host>/oauth/google/callback registered in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Gemini AI (optional)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
